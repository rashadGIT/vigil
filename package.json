{
  "name": "vigil",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "demo:reset": "docker-compose up -d && cd backend && npx prisma migrate deploy && npx prisma db seed && cd ..",
    "demo:seed": "cd backend && npx prisma db seed && cd ..",
    "dev": "./dev.sh",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:watch": "npm run test:watch --workspaces --if-present",
    "test:coverage": "npm run test:coverage --workspaces --if-present",
    "test:e2e": "npm run test:e2e --workspaces --if-present",
    "test:e2e:ui": "npm run test:e2e:ui --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "type-check": "npm run type-check --workspaces --if-present",
    "prepare": "husky"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@sentry/nestjs": "^10.52.0",
    "@sentry/node": "^10.52.0",
    "class-validator": "^0.15.1"
  }
}
