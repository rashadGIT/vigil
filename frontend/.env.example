# ============================================================
# Vigil Frontend — Environment Variables
# Copy this file to .env.local and populate values for your environment.
# NEVER commit .env.local — only .env.example is safe to commit.
# NOTE: NEXT_PUBLIC_* variables are bundled into the client bundle.
# Do NOT put secrets in NEXT_PUBLIC_* variables.
# ============================================================

# ------------------------------------
# API
# ------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3001

# ------------------------------------
# App Domain (used for tenant subdomain routing in middleware.ts)
# ------------------------------------
NEXT_PUBLIC_APP_DOMAIN=localhost

# ------------------------------------
# AWS Cognito — Amplify SDK Config
# Values available after Phase 8 CDK deploy (AuthStack outputs)
# ------------------------------------
NEXT_PUBLIC_USER_POOL_ID=us-east-2_REPLACE_AFTER_CDK_DEPLOY
NEXT_PUBLIC_USER_POOL_CLIENT_ID=REPLACE_AFTER_CDK_DEPLOY
NEXT_PUBLIC_AWS_REGION=us-east-2

# ------------------------------------
# Local Dev Auth Bypass
# Set NEXT_PUBLIC_DEV_AUTH_BYPASS=true locally to mirror backend DEV_AUTH_BYPASS.
# When true, the frontend injects the x-dev-user header on all API requests.
# NEVER set to true in production.
# Both NEXT_PUBLIC_DEV_AUTH_BYPASS and backend DEV_AUTH_BYPASS must be set together.
# ------------------------------------
NEXT_PUBLIC_DEV_AUTH_BYPASS=false

# ------------------------------------
# Local Dev Tenant (for DEV_AUTH_BYPASS mode only)
# Copy the sunrise tenant ID from `npx prisma db seed` output (Phase 11).
# ------------------------------------
NEXT_PUBLIC_DEV_TENANT_ID=
