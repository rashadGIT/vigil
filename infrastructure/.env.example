# ============================================================
# Vigil Infrastructure (CDK) — Environment Variables
# Copy this file to .env and populate values for CDK deployments.
# The AWS_PROFILE vigil must be configured in ~/.aws/config (not here).
# ============================================================

# ------------------------------------
# CDK Context
# CDK_DEFAULT_ACCOUNT is the Vigil AWS account ID.
# CDK_DEFAULT_REGION is us-east-2 — ALL Vigil infrastructure lives here.
# ------------------------------------
CDK_DEFAULT_ACCOUNT=887067305712
CDK_DEFAULT_REGION=us-east-2

# ------------------------------------
# AWS CLI Profile (configure via: aws configure --profile vigil)
# Do not store credentials here — use ~/.aws/credentials or IAM instance roles.
# ------------------------------------
AWS_PROFILE=vigil
